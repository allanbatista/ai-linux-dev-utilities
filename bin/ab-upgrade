#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f -- "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname -- "$SCRIPT_PATH")"
PROJECT_DIR="$(dirname -- "$SCRIPT_DIR")"
DRY_RUN=0

INSTALL_PATH="${AB_INSTALL_PATH:-/usr/local/bin/ab}"
COMPLETION_FILE="${AB_COMPLETION_FILE:-$HOME/.local/share/bash-completion/completions/ab}"

show_help() {
    echo "ab upgrade - Update this ab installation"
    echo ""
    echo "Usage: ab upgrade [--dry-run]"
    echo ""
    echo "Updates the installed checkout with git, refreshes the virtualenv"
    echo "dependencies, and verifies the ab symlink and bash completion."
    echo ""
    echo "Options:"
    echo "  --dry-run         Print the commands/actions without changing state"
    echo "  -h, --help        Show this help message"
    echo ""
    echo "Behavior:"
    echo "  Runs non-interactively and never asks for input."
    echo "  Preserves local changes; normal mode stops on a dirty worktree."
    echo "  Returns non-zero when any upgrade step fails."
}

print_cmd() {
    local arg
    printf '+'
    for arg in "$@"; do
        printf ' %q' "$arg"
    done
    printf '\n'
}

fail() {
    echo "Error: $*" >&2
    exit 1
}

run_step() {
    local label="$1"
    shift

    echo "==> $label"
    if [ "$DRY_RUN" -eq 1 ]; then
        print_cmd "$@"
        return 0
    fi

    if ! "$@"; then
        fail "failed during $label"
    fi
}

require_tool() {
    local tool="$1"
    command -v "$tool" >/dev/null 2>&1 || fail "$tool is required"
}

ensure_git_checkout() {
    if [ "$DRY_RUN" -eq 1 ]; then
        print_cmd git -C "$PROJECT_DIR" rev-parse --is-inside-work-tree
        return 0
    fi

    git -C "$PROJECT_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1 ||
        fail "$PROJECT_DIR is not a git checkout"
}

ensure_clean_worktree() {
    local status

    if [ "$DRY_RUN" -eq 1 ]; then
        print_cmd git -C "$PROJECT_DIR" status --porcelain --untracked-files=all
        echo "# normal mode stops here if the worktree is dirty"
        return 0
    fi

    status="$(git -C "$PROJECT_DIR" status --porcelain --untracked-files=all)"
    if [ -n "$status" ]; then
        echo "$status" >&2
        fail "worktree is not clean; commit, stash, or remove local changes before upgrading"
    fi
}

safe_link() {
    local label="$1"
    local target="$2"
    local path="$3"
    local dir
    local current

    dir="$(dirname -- "$path")"

    if [ -L "$path" ]; then
        current="$(readlink -f -- "$path")"
        if [ "$current" = "$target" ]; then
            echo "==> $label already configured"
            return 0
        fi
        fail "$label exists and points to $current; not overwriting"
    fi

    if [ -e "$path" ]; then
        fail "$label exists and is not a symlink: $path"
    fi

    echo "==> configure $label"
    if [ "$DRY_RUN" -eq 1 ]; then
        print_cmd mkdir -p "$dir"
        if [ -d "$dir" ] && [ -w "$dir" ]; then
            print_cmd ln -s "$target" "$path"
        else
            print_cmd sudo -n ln -s "$target" "$path"
        fi
        return 0
    fi

    mkdir -p "$dir" || fail "failed during configure $label"
    if [ -w "$dir" ]; then
        ln -s "$target" "$path"
    else
        sudo -n ln -s "$target" "$path" || fail "failed during configure $label"
    fi
}

while [ $# -gt 0 ]; do
    case "$1" in
        --dry-run)
            DRY_RUN=1
            shift
            ;;
        -h|--help)
            show_help
            exit 0
            ;;
        *)
            fail "unknown option '$1'"
            ;;
    esac
done

require_tool git
require_tool python3

echo "Project: $PROJECT_DIR"
if [ "$DRY_RUN" -eq 1 ]; then
    echo "Dry run: no changes will be made"
fi

ensure_git_checkout
ensure_clean_worktree

run_step "git fetch" git -C "$PROJECT_DIR" fetch --prune origin
run_step "git pull" git -C "$PROJECT_DIR" pull --ff-only
run_step "create virtualenv" python3 -m venv "$PROJECT_DIR/.venv"
run_step "upgrade pip" "$PROJECT_DIR/.venv/bin/python" -m pip install --upgrade pip -q
run_step "install dependencies" "$PROJECT_DIR/.venv/bin/python" -m pip install -r "$PROJECT_DIR/requirements.txt" -q

safe_link "ab symlink" "$(readlink -f -- "$PROJECT_DIR/bin/ab")" "$INSTALL_PATH"
safe_link "bash completion" "$(readlink -f -- "$PROJECT_DIR/completions/ab.bash-completion")" "$COMPLETION_FILE"

if [ "$DRY_RUN" -eq 1 ]; then
    echo "Dry run complete"
else
    echo "Upgrade complete"
fi
